# Sepolia 部署配置（复制为 .env 并填入真实值）
# Zama Protocol 当前在标准 Sepolia 上运行（chainId 11155111）

# RPC URL（推荐）
# 选项 1：免费公共 RPC（无需注册）
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
# 选项 2：Infura（需要 https://infura.io 申请 API key）
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# 选项 3：Alchemy（需要 https://alchemy.com 申请 API key）
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# 测试钱包私钥（重要：用一个新建的钱包，不要用日常用的！）
PRIVATE_KEY=0x...

# 部署时的合约参数（可选）
DECLARED_TOTAL=1000
RECIPIENT_COUNT=2
AUDITOR_ADDRESS=

# Etherscan API key（可选，用于合约验证）
# ETHERSCAN_API_KEY=
