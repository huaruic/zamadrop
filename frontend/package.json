{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "e2e:dev": "VITE_E2E_SINGLE_WALLET=true vite --host 127.0.0.1 --port 5173 --strictPort",
    "e2e:wallet-cache": "synpress ./e2e/wallet-setup",
    "e2e:wallet-cache:connected": "synpress ./e2e/wallet-setup-connected",
    "e2e": "playwright test -c e2e/playwright.config.ts",
    "e2e:ui-regression": "playwright test -c e2e/playwright.config.ts e2e/specs/role-boundaries-ui.spec.ts",
    "e2e:wallet-regression": "playwright test -c e2e/playwright.config.ts e2e/specs/metamask-connect.spec.ts e2e/specs/recipient-decrypt.spec.ts e2e/specs/auditor-decrypt.spec.ts e2e/specs/reject-signature-retry.spec.ts",
    "e2e:ui": "playwright test -c e2e/playwright.config.ts --ui"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.8",
    "@zama-fhe/relayer-sdk": "^0.4.2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "viem": "^2.48.8",
    "wagmi": "^3.6.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.48.2",
    "@synthetixio/synpress": "4.1.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.2.3",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
