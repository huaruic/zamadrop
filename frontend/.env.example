# Override the deployed campaign address. When unset, falls back to
# CONTRACTS.campaign in src/config.ts. Useful for E2E testing against a
# fresh deployment without editing source.
VITE_CAMPAIGN_ADDRESS=

# Override the ERC20 token address. Same fallback semantics. Token address
# is also readable from the campaign contract itself, so most callers
# don't need this.
VITE_TOKEN_ADDRESS=
